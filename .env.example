# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# ── Database ────────────────────────────────────────────────────────────────
# Local dev: matches docker-compose.yml defaults
DATABASE_URL=postgresql+asyncpg://hikecast:hikecast@localhost:5432/hikecast

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_before_deploying
JWT_LIFETIME_SECONDS=900
REFRESH_LIFETIME_SECONDS=2592000
COOKIE_SECURE=false   # set to true in production (requires HTTPS)

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Open-Meteo (no API key needed — free tier, CC BY 4.0) ──────────────────
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1
OPEN_METEO_GEOCODE_URL=https://geocoding-api.open-meteo.com/v1

# ── Cache ───────────────────────────────────────────────────────────────────
FORECAST_CACHE_TTL_MINUTES=30
CLIMATOLOGY_YEARS=10

# ── Frontend (Vite reads VITE_ prefixed vars) ───────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
